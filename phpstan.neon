parameters:
    paths:
        - src/inc/apiv2
        - ci/phpunit
        - src/dba
        - src/inc/api
    level: 4
    treatPhpDocTypesAsCertain: false 
    scanDirectories:
        - src/dba
        - src/inc
    excludePaths:
        # Exclude the DBA tests due PHPStan doing weird complaints
        - ci/phpunit/dba/AbstractModelFactoryTest.php